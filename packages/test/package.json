{
  "name": "@blueprintui/test",
  "version": "0.0.0",
  "description": "",
  "main": "index.js",
  "author": "Crylan Software",
  "license": "MIT",
  "type": "module",
  "files": [
    "package.json",
    "README.md",
    "LICENSE.md",
    "dist/**/*"
  ],
  "sideEffects": [
    "./dist/include/*.js"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*/index.js",
    "./wtr.js": "./dist/*/wtr.js"
  },
  "scripts": {
    "build": "wireit"
  },
  "wireit": {
    "build": {
      "command": "tsc",
      "files": [
        "./src/**/*",
        "./tsconfig.lib.json",
        "./package.json"
      ],
      "output": [
        "./dist"
      ]
    }
  }
}
