{
  "name": "@blueprintui/components",
  "version": "0.0.0",
  "main": "./index.js",
  "module": "./index.js",
  "typings": "./index.d.ts",
  "type": "module",
  "customElements": "./dist/custom-elements.json",
  "html.customData": [
    "./vscode.html-custom-data.json"
  ],
  "css.customData": [
    "./vscode.css-custom-data.json"
  ],
  "license": "MIT",
  "author": "Crylan Software",
  "homepage": "https://blueprintui.dev",
  "description": "Web Component Library for building user interfaces",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueprintui/blueprintui.git"
  },
  "bugs": {
    "url": "https://github.com/blueprintui/blueprintui/issues"
  },
  "keywords": [
    "web component",
    "design system",
    "ui"
  ],
  "files": [
    "package.json",
    "README.md",
    "LICENSE.md",
    "dist/**/*"
  ],
  "sideEffects": [
    "./dist/include/*.js"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./custom-elements.json": "./dist/custom-elements.json",
    "./include/*.js": {
      "types": "./dist/include/*.d.ts",
      "default": "./dist/include/*.js"
    },
    "./internals": {
      "types": "./dist/internals/index.d.ts",
      "default": "./dist/internals/index.js"
    },
    "./integration/*": {
      "types": "./dist/integration/*",
      "default": "./dist/integration/*"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "default": "./dist/*/index.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@blueprintui/icons": "workspace:^",
    "@blueprintui/themes": "workspace:^",
    "@blueprintui/typewriter": "workspace:^",
    "lit": "^3.1.4",
    "tslib": "^2.6.3"
  },
  "optionalDependencies": {
    "@blueprintui/layout": "workspace:^",
    "@blueprintui/typography": "workspace:^",
    "modern-normalize": "^2.0.0"
  },
  "devDependencies": {
    "@blueprintui/test": "workspace:^",
    "del-cli": "5.1.0"
  },
  "scripts": {
    "ci": "wireit",
    "start": "wireit",
    "build": "wireit",
    "build:watch": "wireit",
    "drafter": "wireit",
    "drafter:watch": "wireit",
    "lint:elements": "wireit",
    "test": "wireit",
    "test:watch": "node ../test/dist/wtr.js --watch",
    "test:unit": "wireit",
    "test:coverage": "wireit",
    "test:a11y": "wireit",
    "test:performance": "wireit",
    "test:visual": "wireit",
    "test:visual:update": "wireit",
    "test:api": "wireit",
    "test:api:update": "wireit",
    "gen:element": "npx plop element",
    "publish": "wireit",
    "types": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build",
        "types",
        "drafter",
        "test",
        "test:performance"
      ]
    },
    "start": {
      "dependencies": [
        "build:watch",
        "drafter:watch"
      ]
    },
    "build": {
      "command": "bp build",
      "dependencies": [
        "../themes:build",
        "../layout:build",
        "../typography:build",
        "../typewriter:build",
        "../icons:build"
      ],
      "files": [
        "./src/**/*",
        "!./src/**/*.spec.ts",
        "!./src/**/*.performance.ts",
        "!./src/**/*.visual.ts",
        "./blueprint.config.js",
        "./tsconfig.lib.json",
        "./tsconfig.json",
        "./package.json"
      ],
      "output": [
        "./dist"
      ]
    },
    "build:watch": {
      "command": "bp build --watch",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "drafter": {
      "command": "drafter build",
      "files": [
        "./src/**/*",
        "./blueprint.config.js"
      ],
      "output": [
        "./.drafter"
      ],
      "dependencies": [
        "build"
      ]
    },
    "drafter:watch": {
      "command": "drafter build --watch",
      "service": true,
      "dependencies": [
        "build"
      ]
    },
    "lint:elements": {
      "command": "lit-analyzer ./src"
    },
    "test": {
      "dependencies": [
        "test:api",
        "test:unit",
        "test:visual"
      ]
    },
    "test:unit": {
      "command": "del ./.coverage && node ../test/dist/wtr.js",
      "dependencies": [
        "../test:build",
        "build"
      ],
      "files": [
        "./src/**/*",
        "!./src/**/*.performance.ts",
        "!./src/**/*.visual.ts",
        "!./src/**/*.examples.js",
        "./web-dev-server.config.mjs",
        "./web-test-runner.config.mjs",
        "./tsconfig.spec.json",
        "./tsconfig.json"
      ],
      "output": []
    },
    "test:coverage": {
      "command": "del ./.coverage && node ../test/dist/wtr.js --coverage",
      "dependencies": [],
      "files": [
        "./src/**/*",
        "!./src/**/*.spec.ts",
        "!./src/**/*.examples.js",
        "./web-dev-server.config.mjs",
        "./web-test-runner.config.mjs",
        "./web-test-runner.performance.mjs"
      ],
      "output": [
        "./.coverage"
      ]
    },
    "test:a11y": {
      "command": "node ../test/dist/wtr.js --config ./web-test-runner.a11y.mjs",
      "dependencies": [
        "../test:build",
        "build"
      ],
      "files": [
        "./src/**/*",
        "./web-dev-server.config.mjs",
        "./web-test-runner.config.mjs"
      ],
      "output": []
    },
    "test:performance": {
      "command": "node ../test/dist/wtr.js --config ./web-test-runner.performance.mjs",
      "dependencies": [
        "../test:build",
        "build"
      ],
      "files": [
        "./src/**/*",
        "!./src/**/*.spec.ts",
        "!./src/**/*.examples.js",
        "./web-dev-server.config.mjs",
        "./web-test-runner.config.mjs",
        "./web-test-runner.performance.mjs"
      ],
      "output": []
    },
    "test:visual": {
      "command": "node ../test/dist/wtr.js --config ./web-test-runner.visual.mjs",
      "dependencies": [
        "../test:build",
        "build"
      ],
      "files": [
        "./src/**/*",
        "!./src/**/*.spec.ts",
        "./web-dev-server.config.mjs",
        "./web-test-runner.visual.mjs"
      ],
      "output": []
    },
    "test:visual:update": {
      "command": "node ../test/dist/wtr.js --update-visual-baseline --config ./web-test-runner.visual.mjs",
      "dependencies": [
        "../test:build",
        "build"
      ],
      "files": [
        "./src/**/*",
        "!./src/**/*.spec.ts",
        "./web-dev-server.config.mjs",
        "./web-test-runner.visual.mjs"
      ],
      "output": [
        "screenshots/Chromium/baseline/**/*.png"
      ]
    },
    "test:api": {
      "command": "bp api --test",
      "dependencies": [
        "build"
      ],
      "files": [
        "./src/**/*"
      ],
      "output": []
    },
    "test:api:update": {
      "command": "bp api --update",
      "dependencies": [
        "build"
      ]
    },
    "publish": {
      "command": "cd ./dist && npm publish --access public",
      "dependencies": [
        "ci"
      ]
    },
    "types": {
      "command": "node types.js",
      "dependencies": [
        "build"
      ]
    }
  }
}
