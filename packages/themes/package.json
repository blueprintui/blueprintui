{
  "name": "@blueprintui/themes",
  "version": "0.0.0",
  "main": "index.js",
  "license": "MIT",
  "author": "Crylan Software",
  "homepage": "https://blueprintui.dev",
  "description": "Themes and Design Tokens for Blueprint UI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueprintui/blueprintui.git"
  },
  "bugs": {
    "url": "https://github.com/blueprintui/blueprintui/issues"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": "./dist/*"
  },
  "keywords": [
    "BlueprintUI",
    "theme",
    "design tokens",
    "css"
  ],
  "files": [
    "package.json",
    "README.md",
    "LICENSE.md",
    "dist/**/*"
  ],
  "devDependencies": {
    "wireit": "0.14.4",
    "@blueprintui/layout": "workspace:^",
    "@blueprintui/typography": "workspace:^"
  },
  "scripts": {
    "ci": "wireit",
    "build": "wireit",
    "test": "wireit",
    "publish": "wireit"
  },
  "wireit": {
    "ci": {
      "dependencies": [
        "build",
        "test"
      ]
    },
    "publish": {
      "command": "cd ./dist && npm publish --access public",
      "dependencies": [
        "ci"
      ]
    },
    "build": {
      "command": "node ./style-dictionary.config.js",
      "files": [
        "./style-dictionary.config.js",
        "./src/**/*",
        "./package.json"
      ],
      "output": [
        "./dist/**"
      ]
    },
    "test": {
      "command": "node ../test/dist/wtr.js --config ./web-test-runner.config.mjs",
      "files": [
        "./style-dictionary.config.js",
        "./web-test-runner.config.mjs",
        "./src/**/*",
        "./package.json"
      ],
      "dependencies": [
        "../test:build",
        "build"
      ],
      "output": []
    }
  }
}
